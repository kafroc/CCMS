# =============================================================================
# cc-security environment variables
# Copy this file to `.env` and fill in real values before starting the server.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment mode
# -----------------------------------------------------------------------------
# `production` enables strict validation at startup (weak secrets, missing
# CORS origins, or a hard-coded ADMIN_INITIAL_PASSWORD will cause the app to
# refuse to start). Use `development` locally.
APP_ENV=development
DEBUG=true

# -----------------------------------------------------------------------------
# Secrets
# -----------------------------------------------------------------------------
# JWT signing key. MUST be at least 32 chars and not one of the well-known
# insecure defaults. Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-random-32-byte-string

# Key used to encrypt stored AI-provider API keys.
# REQUIRED in production (APP_ENV=production) — the server will refuse to start
# if this is unset. In development, leaving it empty causes a fallback to
# SECRET_KEY-derived encryption (functional but not recommended).
# Generate a Fernet key with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Install_for_Linux.sh auto-generates this key on first run.
ENCRYPTION_KEY=

ACCESS_TOKEN_EXPIRE_HOURS=8

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of origins allowed to call the API. In `production`
# mode this MUST be set to a non-wildcard value.
# Example: ALLOWED_ORIGINS=https://cc-sec.example.com,https://admin.example.com
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cc_security
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/cc_security
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/cc_security

# -----------------------------------------------------------------------------
# Redis (used by ARQ task queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Network binding (both docker and local modes honour these)
# -----------------------------------------------------------------------------
# Host interface the backend binds to. Use 0.0.0.0 to accept connections from
# any network interface (required for remote / cloud access). Use 127.0.0.1 to
# restrict to the local machine.
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Port the frontend is served on. Default is 80 so docker and local modes
# expose the UI at the same URL (http://<host>/). On Linux, binding to 80
# typically requires root; for non-root local runs pick something like 8080.
# The vite dev server (local mode) also binds 0.0.0.0 so it is reachable
# from other hosts on the network.
FRONTEND_PORT=8080

# -----------------------------------------------------------------------------
# Uploads / storage
# -----------------------------------------------------------------------------
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=500

# -----------------------------------------------------------------------------
# Admin bootstrap
# -----------------------------------------------------------------------------
# Default admin login password. Displayed in the terminal each time the
# service starts. The first login ALWAYS forces a mandatory password change.
# Change this to a custom value before deploying to a shared environment.
ADMIN_INITIAL_PASSWORD=Admin@123456
